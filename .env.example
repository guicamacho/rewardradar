# Availability provider (sources/external-api.ts)
AWARD_API_BASE_URL=
AWARD_API_KEY=

# Shared availability backend (sources/availability-service.ts ->
# @rewardradar/availability-service contract). The key is the
# x-availability-key shared secret the service requires.
AVAILABILITY_SERVICE_URL=
AVAILABILITY_SERVICE_KEY=

# Upstream availability provider for the route-list generator
# (availability-service generate-routes.ts). Partner API key, env-only.
# AERO_API_URL defaults to the public vendor endpoint if unset.
AERO_API_KEY=
AERO_API_URL=
# Optional: where generate-routes writes CSVs (defaults to the package ./data)
ROUTES_OUTPUT_DIR=

# Telegram delivery (sinks.ts TelegramSink)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_BR=
TELEGRAM_CHAT_ID_ES=

# Webhook subscribers (sinks.ts WebhookSink)
ALERTS_WEBHOOK_URL=
ALERTS_WEBHOOK_SECRET=

# Storage (roadmap item 2)
DATABASE_URL=
